{
  "name": "grade-inteligente",
  "private": true,
  "version": "0.1.6",
  "type": "module",
  "main": "electron/main.cjs",
  "author": "Professor Fabião",
  "description": "Grade Inteligente — agenda escolar com exportação ICS/PDF e empacotamento desktop",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "dev:web": "vite",
    "build:web": "vite build",
    "preview:web": "vite preview",
    "dev:electron": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "start:electron": "electron .",
    "build:electron": "$env:ELECTRON='true'; npm run build:web; electron-builder --win nsis",
    "build:electron:dir": "$env:ELECTRON='true'; npm run build:web; electron-builder --win dir",
    "icon:generate": "powershell -ExecutionPolicy Bypass -File ./build/make-icon.ps1",
    "build:electron:nsis": "$env:ELECTRON='true'; $env:CSC_IDENTITY_AUTO_DISCOVERY='false'; $env:ELECTRON_BUILDER_DISABLE_WIN_CODE_SIGNING='true'; npm run build:web; electron-builder --win nsis",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "electron-store": "^11.0.2",
    "file-saver": "^2.0.5",
    "jspdf": "^3.0.4",
    "jspdf-autotable": "^5.0.2",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^2.1.8",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0",
    "jsdom": "^27.3.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^7.2.4",
    "vitest": "^2.1.8",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.gradeinteligente.app",
    "productName": "Grade Inteligente",
    "copyright": "© 2025 drackercompany",
    "directories": {
      "output": "executaveis"
    },
    "files": [
      "dist/**/*",
      "electron/**/*.cjs",
      "package.json",
      "node_modules/electron-store/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/electron-store/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Grade-Inteligente-${version}-Setup.exe",
      "publisherName": "drackercompany",
      "signingHashAlgorithms": [
        "sha256"
      ],
      "sign": null,
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Grade Inteligente",
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "license": false,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    }
  }
}